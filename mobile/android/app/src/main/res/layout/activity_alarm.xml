<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1E1E26">

    <!-- Pulsing rings — sit behind all content, non-interactive -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clickable="false"
        android:focusable="false">

        <View
            android:id="@+id/ring1"
            android:layout_width="280dp"
            android:layout_height="280dp"
            android:layout_gravity="center"
            android:background="@drawable/bg_alarm_ring" />

        <View
            android:id="@+id/ring2"
            android:layout_width="420dp"
            android:layout_height="420dp"
            android:layout_gravity="center"
            android:background="@drawable/bg_alarm_ring" />

        <View
            android:id="@+id/ring3"
            android:layout_width="560dp"
            android:layout_height="560dp"
            android:layout_gravity="center"
            android:background="@drawable/bg_alarm_ring" />
    </FrameLayout>

    <!-- Main content — space-between layout using weight=1 spacers -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingTop="48dp"
        android:paddingBottom="48dp">

        <!-- Top bar: ALARM FIRING + schedule name -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ALARM FIRING"
                android:textSize="11sp"
                android:textColor="#7B6FFF"
                android:textStyle="bold"
                android:letterSpacing="0.23" />

            <TextView
                android:id="@+id/tvScheduleName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="13sp"
                android:textColor="#6A6A8A"
                android:layout_marginTop="5dp"
                android:visibility="gone" />
        </LinearLayout>

        <!-- Spacer -->
        <Space
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <!-- Clock -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal">

            <TextView
                android:id="@+id/tvClockTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="76sp"
                android:textColor="#F2F2FF"
                android:textStyle="bold"
                android:letterSpacing="-0.04"
                android:lineSpacingExtra="-4dp" />

            <TextView
                android:id="@+id/tvClockAmpm"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="20sp"
                android:textColor="#7B6FFF"
                android:textStyle="bold"
                android:letterSpacing="0.05"
                android:layout_marginTop="4dp" />
        </LinearLayout>

        <!-- Spacer -->
        <Space
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <!-- Cards stack -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Current activity card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_alarm_card"
                android:padding="20dp"
                android:elevation="5dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="NOW"
                    android:textSize="10sp"
                    android:textColor="#6A6A8A"
                    android:textStyle="bold"
                    android:letterSpacing="0.2" />

                <!-- Activity name row with blinking dot -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="12dp">

                    <View
                        android:id="@+id/activityDot"
                        android:layout_width="8dp"
                        android:layout_height="8dp"
                        android:background="@drawable/bg_alarm_dot" />

                    <TextView
                        android:id="@+id/tvActivityName"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textSize="17sp"
                        android:textColor="#F2F2FF"
                        android:textStyle="bold"
                        android:layout_marginStart="10dp" />
                </LinearLayout>

                <!-- Time range row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="12dp">

                    <TextView
                        android:id="@+id/tvStartTime"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_alarm_time_chip"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:paddingTop="5dp"
                        android:paddingBottom="5dp"
                        android:textSize="12sp"
                        android:textColor="#A0A0C0" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="→"
                        android:textSize="12sp"
                        android:textColor="#6A6A8A"
                        android:layout_marginStart="8dp"
                        android:layout_marginEnd="8dp" />

                    <TextView
                        android:id="@+id/tvEndTime"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_alarm_time_chip"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:paddingTop="5dp"
                        android:paddingBottom="5dp"
                        android:textSize="12sp"
                        android:textColor="#A0A0C0" />
                </LinearLayout>
            </LinearLayout>

            <!-- Up next card (hidden when no next activity) -->
            <LinearLayout
                android:id="@+id/upNextCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_alarm_up_next"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingTop="16dp"
                android:paddingBottom="16dp"
                android:layout_marginTop="10dp"
                android:elevation="5dp"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvNextActivity"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="#A0A0C0" />

                    <TextView
                        android:id="@+id/tvNextStartTime"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_alarm_time_chip"
                        android:paddingStart="10dp"
                        android:paddingEnd="10dp"
                        android:paddingTop="4dp"
                        android:paddingBottom="4dp"
                        android:textSize="11sp"
                        android:textColor="#6A6A8A"
                        android:layout_marginTop="6dp"
                        android:visibility="gone" />
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="UP NEXT"
                    android:textSize="10sp"
                    android:textColor="#6A6A8A"
                    android:textStyle="bold"
                    android:letterSpacing="0.15" />
            </LinearLayout>
        </LinearLayout>

        <!-- Spacer -->
        <Space
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <!-- Dismiss + Snooze buttons -->
        <LinearLayout
            android:id="@+id/actionsLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/btnDismiss"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Dismiss"
                android:gravity="center"
                android:background="@drawable/bg_alarm_btn_dismiss"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold"
                android:paddingTop="18dp"
                android:paddingBottom="18dp"
                android:clickable="true"
                android:focusable="true" />

            <Space android:layout_width="12dp" android:layout_height="0dp" />

            <TextView
                android:id="@+id/btnSnooze"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Snooze · 5 min"
                android:gravity="center"
                android:background="@drawable/bg_alarm_btn_snooze"
                android:textColor="#A0A0C0"
                android:textSize="15sp"
                android:paddingTop="18dp"
                android:paddingBottom="18dp"
                android:clickable="true"
                android:focusable="true" />
        </LinearLayout>

        <!-- Snoozed card (replaces buttons after snooze tap) -->
        <LinearLayout
            android:id="@+id/snoozedCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:background="@drawable/bg_alarm_snoozed"
            android:paddingTop="20dp"
            android:paddingBottom="20dp"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SNOOZED"
                android:textSize="11sp"
                android:textColor="#F59E0B"
                android:textStyle="bold"
                android:letterSpacing="0.2" />

            <TextView
                android:id="@+id/tvSnoozeCountdown"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="32sp"
                android:textColor="#F2F2FF"
                android:textStyle="bold"
                android:layout_marginTop="6dp" />
        </LinearLayout>

    </LinearLayout>
</FrameLayout>